<style>
  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #1a1a1a;
    --border: rgba(255,255,255,0.07);
    --text: #f0f0f0;
    --text-muted: #555;
    --text-dim: #333;
    --weekend: #1c1c1c;
    --holiday: #161616;
    --grad1: #b44fff;
    --grad2: #6a8fff;
    --grad3: #ff6fd8;
    --reels: #f5c842;
    --carousel: #1e3a8a;
    --stories: #22c9a0;
    --radius: 12px;
    --cell-radius: 10px;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
padding: 32px 24px 48px;
}

/* HEADER */
.header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 36px;
flex-wrap: wrap;
gap: 16px;
}

.header-left {
display: flex;
align-items: center;
gap: 20px;
}

.logo-wrap {
width: 56px;
height: 56px;
border-radius: 50%;
background: #000;
border: 1.5px solid rgba(180,79,255,0.4);
overflow: hidden;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}

.logo-wrap img {
width: 100%;
height: 100%;
object-fit: cover;
}

.header-titles {}
.header-sub {
font-family: ‘DM Sans’, sans-serif;
font-size: 11px;
font-weight: 500;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–grad2);
margin-bottom: 4px;
}

.header-title {
font-family: ‘Syne’, sans-serif;
font-size: 22px;
font-weight: 800;
letter-spacing: -0.02em;
background: linear-gradient(90deg, var(–grad1), var(–grad2), var(–grad3));
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
line-height: 1.1;
}

/* THEME TOGGLE */
.theme-toggle {
display: flex;
align-items: center;
gap: 8px;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 999px;
padding: 6px 14px;
cursor: pointer;
font-size: 12px;
color: var(–text-muted);
font-family: ‘DM Sans’, sans-serif;
transition: all 0.2s;
user-select: none;
}
.theme-toggle:hover { border-color: rgba(180,79,255,0.4); color: var(–text); }
.theme-toggle .dot {
width: 8px; height: 8px; border-radius: 50%;
background: linear-gradient(135deg, var(–grad1), var(–grad2));
}

/* LEGEND */
.legend {
display: flex;
align-items: center;
gap: 20px;
flex-wrap: wrap;
}

.legend-item {
display: flex;
align-items: center;
gap: 8px;
font-size: 12px;
color: #888;
font-weight: 500;
}

.legend-dot {
width: 10px; height: 10px; border-radius: 3px;
}
.legend-dot.reels { background: var(–reels); }
.legend-dot.carousel { background: #4a7fff; }
.legend-dot.stories { background: var(–stories); }
.legend-dot.weekend { background: #2a2a2a; border: 1px solid #333; }
.legend-dot.holiday { background: #1e1e1e; border: 1px solid #2a2a2a; }

/* MONTHS WRAPPER */
.months-wrapper {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 24px;
}

@media (max-width: 900px) {
.months-wrapper { grid-template-columns: 1fr; }
}

/* MONTH CARD */
.month-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 16px;
padding: 20px;
position: relative;
overflow: hidden;
}

.month-card::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: linear-gradient(90deg, var(–grad1), var(–grad2), var(–grad3));
opacity: 0.7;
}

.month-name {
font-family: ‘Syne’, sans-serif;
font-size: 18px;
font-weight: 700;
letter-spacing: -0.01em;
margin-bottom: 16px;
color: var(–text);
}

.month-name span {
font-weight: 400;
color: var(–text-muted);
font-size: 14px;
margin-left: 8px;
}

/* CALENDAR GRID */
.cal-grid {
display: grid;
grid-template-columns: repeat(7, 1fr);
gap: 4px;
}

.day-header {
text-align: center;
font-size: 10px;
font-weight: 600;
letter-spacing: 0.08em;
text-transform: uppercase;
color: var(–text-dim);
padding: 6px 0;
}

.day-header.weekend-h { color: #3a3a3a; }

/* DAY CELL */
.day-cell {
aspect-ratio: 1;
border-radius: var(–cell-radius);
border: 1px solid transparent;
display: flex;
flex-direction: column;
align-items: center;
justify-content: flex-start;
padding: 6px 4px 4px;
position: relative;
cursor: pointer;
transition: all 0.15s ease;
min-height: 52px;
}

.day-cell.empty { cursor: default; }

.day-cell.normal {
background: var(–surface2);
border-color: var(–border);
}

.day-cell.normal:hover {
border-color: rgba(180,79,255,0.4);
background: #1f1f1f;
transform: scale(1.03);
}

.day-cell.weekend-day {
background: var(–weekend);
border-color: transparent;
}

.day-cell.holiday-day {
background: var(–holiday);
border-color: transparent;
}

.day-num {
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 600;
line-height: 1;
}

.day-cell.normal .day-num { color: var(–text); }
.day-cell.weekend-day .day-num { color: #3a3a3a; }
.day-cell.holiday-day .day-num { color: #2e2e2e; }

/* TAGS AREA */
.tags-area {
display: flex;
flex-wrap: wrap;
gap: 2px;
justify-content: center;
margin-top: 4px;
width: 100%;
}

.tag {
border-radius: 4px;
font-size: 7px;
font-weight: 700;
letter-spacing: 0.06em;
text-transform: uppercase;
padding: 2px 4px;
line-height: 1;
cursor: pointer;
transition: transform 0.1s, opacity 0.1s;
user-select: none;
}

.tag:hover { transform: scale(1.15); }

.tag.reels {
background: rgba(245,200,66,0.18);
color: var(–reels);
border: 1px solid rgba(245,200,66,0.3);
}

.tag.carousel {
background: rgba(74,127,255,0.18);
color: #7aaeff;
border: 1px solid rgba(74,127,255,0.3);
}

.tag.stories {
background: rgba(34,201,160,0.18);
color: var(–stories);
border: 1px solid rgba(34,201,160,0.3);
}

/* TAG LABEL TEXT */
.tag-label {
font-size: 7px;
font-weight: 600;
text-align: center;
margin-top: 2px;
line-height: 1.2;
max-width: 100%;
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
width: 90%;
color: #777;
}

/* POPUP */
.popup-overlay {
display: none;
position: fixed;
inset: 0;
background: rgba(0,0,0,0.7);
backdrop-filter: blur(4px);
z-index: 100;
align-items: center;
justify-content: center;
}
.popup-overlay.active { display: flex; }

.popup {
background: #141414;
border: 1px solid rgba(180,79,255,0.3);
border-radius: 16px;
padding: 24px;
width: 320px;
max-width: 90vw;
position: relative;
}

.popup::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0; height: 2px;
border-radius: 16px 16px 0 0;
background: linear-gradient(90deg, var(–grad1), var(–grad2), var(–grad3));
}

.popup-title {
font-family: ‘Syne’, sans-serif;
font-size: 16px;
font-weight: 700;
margin-bottom: 16px;
color: var(–text);
}

.popup-section { margin-bottom: 14px; }
.popup-section-label {
font-size: 10px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-muted);
margin-bottom: 8px;
}

.tag-options {
display: flex;
gap: 8px;
flex-wrap: wrap;
}

.tag-option {
border-radius: 8px;
padding: 8px 14px;
font-size: 12px;
font-weight: 600;
cursor: pointer;
border: 2px solid transparent;
transition: all 0.15s;
user-select: none;
}

.tag-option.reels-opt {
background: rgba(245,200,66,0.12);
color: var(–reels);
border-color: rgba(245,200,66,0.25);
}
.tag-option.reels-opt:hover, .tag-option.reels-opt.selected {
background: rgba(245,200,66,0.28);
border-color: var(–reels);
}

.tag-option.carousel-opt {
background: rgba(74,127,255,0.12);
color: #7aaeff;
border-color: rgba(74,127,255,0.25);
}
.tag-option.carousel-opt:hover, .tag-option.carousel-opt.selected {
background: rgba(74,127,255,0.28);
border-color: #4a7fff;
}

.tag-option.stories-opt {
background: rgba(34,201,160,0.12);
color: var(–stories);
border-color: rgba(34,201,160,0.25);
}
.tag-option.stories-opt:hover, .tag-option.stories-opt.selected {
background: rgba(34,201,160,0.28);
border-color: var(–stories);
}

.tag-label-input {
width: 100%;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 8px 12px;
font-size: 12px;
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
outline: none;
transition: border-color 0.15s;
}
.tag-label-input:focus { border-color: rgba(180,79,255,0.5); }
.tag-label-input::placeholder { color: var(–text-dim); }

.popup-btns {
display: flex;
gap: 8px;
margin-top: 18px;
}

.btn-save {
flex: 1;
background: linear-gradient(135deg, var(–grad1), var(–grad2));
border: none;
border-radius: 8px;
padding: 10px;
font-size: 13px;
font-weight: 600;
color: white;
cursor: pointer;
font-family: ‘DM Sans’, sans-serif;
transition: opacity 0.15s;
}
.btn-save:hover { opacity: 0.85; }

.btn-clear {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 10px 14px;
font-size: 12px;
color: #666;
cursor: pointer;
font-family: ‘DM Sans’, sans-serif;
transition: all 0.15s;
}
.btn-clear:hover { color: #ff6b6b; border-color: rgba(255,107,107,0.4); }

.btn-close {
background: none;
border: none;
color: #555;
cursor: pointer;
font-size: 18px;
position: absolute;
top: 14px; right: 16px;
line-height: 1;
transition: color 0.15s;
}
.btn-close:hover { color: var(–text); }

/* COUNTER */
.counter-bar {
display: flex;
align-items: center;
gap: 12px;
margin-top: 20px;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 12px;
padding: 14px 20px;
flex-wrap: wrap;
}

.counter-label {
font-size: 11px;
font-weight: 600;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–text-muted);
flex: 1;
min-width: 120px;
}

.counter-items {
display: flex;
gap: 16px;
align-items: center;
flex-wrap: wrap;
}

.counter-item {
display: flex;
align-items: center;
gap: 6px;
font-size: 12px;
}

.counter-num {
font-family: ‘Syne’, sans-serif;
font-size: 20px;
font-weight: 800;
}

.counter-item.reels-c .counter-num { color: var(–reels); }
.counter-item.carousel-c .counter-num { color: #7aaeff; }
.counter-item.stories-c .counter-num { color: var(–stories); }

.counter-item .counter-txt { color: #666; font-size: 11px; }

.total-badge {
margin-left: auto;
background: linear-gradient(135deg, rgba(180,79,255,0.2), rgba(106,143,255,0.2));
border: 1px solid rgba(180,79,255,0.3);
border-radius: 8px;
padding: 6px 14px;
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 700;
}
.total-badge span { color: var(–grad1); }

/* LIGHT THEME */
body.light {
–bg: #f4f4f6;
–surface: #ffffff;
–surface2: #f0f0f3;
–border: rgba(0,0,0,0.08);
–text: #111111;
–text-muted: #999;
–text-dim: #ccc;
–weekend: #e8e8ea;
–holiday: #eeeeef;
}

body.light .day-cell.normal .day-num { color: #1a1a1a; }
body.light .day-cell.weekend-day .day-num { color: #bbb; }
body.light .day-cell.holiday-day .day-num { color: #ccc; }
body.light .day-header { color: #ccc; }
body.light .day-header.weekend-h { color: #ddd; }
body.light .tag-label { color: #aaa; }
body.light .popup { background: #fff; }
body.light .tag-label-input { background: #f5f5f7; color: #111; }
body.light .btn-clear { background: #f5f5f7; }
body.light .counter-bar { background: #fff; }

