<script>
// ── FERIADOS BRASILEIROS 2026 (abril/maio) ──
const HOLIDAYS = new Set([
  '2026-04-03', // Sexta-feira Santa
  '2026-04-05', // Páscoa
  '2026-04-21', // Tiradentes
  '2026-05-01', // Dia do Trabalho
]);

// ── STATE ──
const state = {}; // { 'YYYY-MM-DD': { type: 'reels'|'carousel'|'stories', label: '' } }
let currentCell = null;
let selectedTagType = null;

// ── MONTHS ──
const months = [
  { year: 2026, month: 3, name: 'Abril', short: '2026' },
  { year: 2026, month: 4, name: 'Maio', short: '2026' },
];

const DAY_HEADERS = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
const WEEKEND_IDX = [0, 6];

function isWeekend(dayOfWeek) { return dayOfWeek === 0 || dayOfWeek === 6; }
function isHoliday(dateStr) { return HOLIDAYS.has(dateStr); }
function pad(n) { return String(n).padStart(2,'0'); }
function dateKey(y, m, d) { return `${y}-${pad(m+1)}-${pad(d)}`; }

function buildCalendar() {
  const root = document.getElementById('calendar-root');
  root.innerHTML = '';

  months.forEach(({ year, month, name, short }) => {
    const card = document.createElement('div');
    card.className = 'month-card';

    const title = document.createElement('div');
    title.className = 'month-name';
    title.innerHTML = `${name} <span>${short}</span>`;
    card.appendChild(title);

    const grid = document.createElement('div');
    grid.className = 'cal-grid';

    // Headers
    DAY_HEADERS.forEach((h, i) => {
      const hd = document.createElement('div');
      hd.className = 'day-header' + (WEEKEND_IDX.includes(i) ? ' weekend-h' : '');
      hd.textContent = h;
      grid.appendChild(hd);
    });

    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    // Empty cells
    for (let i = 0; i < firstDay; i++) {
      const empty = document.createElement('div');
      empty.className = 'day-cell empty';
      grid.appendChild(empty);
    }

    // Day cells
    for (let d = 1; d <= daysInMonth; d++) {
      const date = new Date(year, month, d);
      const dow = date.getDay();
      const key = dateKey(year, month, d);

      const cell = document.createElement('div');
      const weekend = isWeekend(dow);
      const holiday = isHoliday(key);

      cell.className = 'day-cell ' + (holiday ? 'holiday-day' : weekend ? 'weekend-day' : 'normal');
      cell.dataset.key = key;
      cell.dataset.label = `${name} ${d}`;

      const num = document.createElement('div');
      num.className = 'day-num';
      num.textContent = d;
      cell.appendChild(num);

      const tagsArea = document.createElement('div');
      tagsArea.className = 'tags-area';
      tagsArea.id = 'tags-' + key;
      cell.appendChild(tagsArea);

      if (!weekend && !holiday) {
        cell.addEventListener('click', () => openPopup(key, `${name} ${d}`));
      }

      grid.appendChild(cell);
      renderCellTags(key);
    }

    card.appendChild(grid);
    root.appendChild(card);
  });
}

function renderCellTags(key) {
  const area = document.getElementById('tags-' + key);
  if (!area) return;
  area.innerHTML = '';
  const entry = state[key];
  if (!entry) return;

  const tag = document.createElement('div');
  tag.className = 'tag ' + entry.type;
  const labels = { reels: 'Reels', carousel: 'Carrossel', stories: 'Stories' };
  tag.textContent = labels[entry.type];
  area.appendChild(tag);

  if (entry.label) {
    const lbl = document.createElement('div');
    lbl.className = 'tag-label';
    lbl.textContent = entry.label;
    area.appendChild(lbl);
  }
}

function updateCounter() {
  let r = 0, c = 0, s = 0;
  Object.values(state).forEach(e => {
    if (e.type === 'reels') r++;
    else if (e.type === 'carousel') c++;
    else if (e.type === 'stories') s++;
  });
  document.getElementById('cnt-reels').textContent = r;
  document.getElementById('cnt-carousel').textContent = c;
  document.getElementById('cnt-stories').textContent = s;
  document.getElementById('cnt-total').textContent = r + c + s;
}

// ── POPUP ──
function openPopup(key, labelText) {
  currentCell = key;
  selectedTagType = null;

  document.getElementById('popup-title').textContent = '📅 ' + labelText;
  document.getElementById('popup-label').value = state[key]?.label || '';

  // Reset options
  document.querySelectorAll('.tag-option').forEach(el => el.classList.remove('selected'));

  if (state[key]) {
    selectedTagType = state[key].type;
    document.querySelector(`.tag-option.${state[key].type}-opt`)?.classList.add('selected');
  }

  document.getElementById('popup-overlay').classList.add('active');
}

function closePopup() {
  document.getElementById('popup-overlay').classList.remove('active');
  currentCell = null;
}

function closePopupOutside(e) {
  if (e.target === document.getElementById('popup-overlay')) closePopup();
}

function selectTag(type) {
  selectedTagType = type;
  document.querySelectorAll('.tag-option').forEach(el => el.classList.remove('selected'));
  document.querySelector(`.tag-option.${type}-opt`)?.classList.add('selected');
}

function saveTag() {
  if (!currentCell || !selectedTagType) { closePopup(); return; }
  const label = document.getElementById('popup-label').value.trim();
  state[currentCell] = { type: selectedTagType, label };
  renderCellTags(currentCell);
  updateCounter();
  closePopup();
}

function clearTag() {
  if (!currentCell) return;
  delete state[currentCell];
  renderCellTags(currentCell);
  updateCounter();
  closePopup();
}

// ── THEME ──
function toggleTheme() {
  const isLight = document.body.classList.toggle('light');
  document.getElementById('theme-label').textContent = isLight ? 'Tema Escuro' : 'Tema Claro';
}

// ── INIT ──
buildCalendar();
updateCounter();
</script>

